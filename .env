# Copy from .env.example and set your values. Restart the server after changes.
PORT=4043
# Local MongoDB (install and run MongoDB, or use MongoDB Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/sports-card
# Min 32 chars for JWT signing
JWT_SECRET=your-secret-min-32-chars-long-change-in-production
# Stripe test key for checkout
STRIPE_SECRET_KEY=sk_test_
